# Atlas do Tempo 3D — modelo de ambiente (12-factor mínimo · Opção A).
# Copie para .env (que é gitignored) e preencha. O bootstrap, a migração, os
# testes e o serviço LEEM estas variáveis; nenhum segredo fica versionado.
#   cp .env.example .env     # depois ajuste os valores
#
# Em DEV local, os valores homônimos casam com os papéis de db/roles/020.
# Em qualquer ambiente compartilhado, TROQUE todos por segredos próprios.
# Rotação/auditoria/gerenciador de segredos (Opção B) ficam para a Etapa 14.

# Senha do usuário 'atlas' (app/migração/testes + POSTGRES_PASSWORD do compose).
ATLAS_DB_PASSWORD=troque-me

# Senhas dos papéis de leitura (db/roles/020 — homônimas em dev: atlas_public / atlas_curatorial).
ATLAS_PUBLIC_PASSWORD=troque-me
ATLAS_CURATORIAL_PASSWORD=troque-me

# Token do header X-Atlas-Auth da porta curatorial (só localhost/rede interna até a E14).
ATLAS_CURATORIAL_TOKEN=troque-me

# Opcionais (têm default; NÃO são segredo): ATLAS_PG_HOST/ATLAS_PG_PORT/ATLAS_PG_DB,
# ATLAS_API_HOST (127.0.0.1), ATLAS_API_PORT (8765).
