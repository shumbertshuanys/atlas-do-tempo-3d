# Modelo de ambiente. Os scripts de migração já usam estes valores por padrão (DSN fixo
# em localhost:5432, casando com docker-compose.yml). Copie para .env se quiser sobrescrever
# em ferramentas que leem .env. NÃO comite o .env real.
POSTGRES_DB=atlas
POSTGRES_USER=atlas
POSTGRES_PASSWORD=atlas
PGHOST=localhost
PGPORT=5432
