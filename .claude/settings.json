{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(docker compose:*)",
      "Bash(psql:*)",
      "Bash(python3 db/migration/migrate.py)",
      "Bash(python3 db/migration/verify.py)",
      "Bash(python3 db/migration/test_a4.py)",
      "Bash(bash scripts/bootstrap.sh)",
      "Bash(python3 -m pip install:*)"
    ],
    "deny": [
      "Bash(docker compose down -v:*)"
    ]
  }
}
